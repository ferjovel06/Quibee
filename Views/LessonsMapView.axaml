<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Quibee.ViewModels"
             xmlns:models="using:Quibee.Models"
             x:Class="Quibee.Views.LessonsMapView"
             x:DataType="vm:LessonsMapViewModel"
             x:Name="Root">

    <Grid ColumnDefinitions="230,*" Background="#1B2352">
        <Border Grid.Column="0" Background="#7CDAF3">
            <Grid RowDefinitions="Auto,*">
                <Image Grid.Row="0"
                       Source="avares://Quibee/Assets/Images/QbitLogo.png"
                       Width="112"
                       Height="72"
                       HorizontalAlignment="Center"
                       Margin="0,16,0,10"/>

                <StackPanel Grid.Row="1" Margin="0,8,0,0" HorizontalAlignment="Stretch">
                    <Border Background="#311B42"
                            CornerRadius="0,30,30,0"
                            Margin="0,2,10,8">
                        <Button Background="Transparent"
                                BorderThickness="0"
                                Padding="16,12"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Right">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Spacing="12">
                                <TextBlock Text="Aprender"
                                           FontFamily="{StaticResource Poppins}"
                                           FontWeight="SemiBold"
                                           FontSize="18"
                                           Foreground="#7CDAF3"
                                           VerticalAlignment="Center"/>
                                <Image Source="avares://Quibee/Assets/Images/Icons/StarLight.png"
                                       Width="18"
                                       Height="18"
                                       VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <Button Background="Transparent"
                            BorderThickness="0"
                            Margin="0,2,10,2"
                            Padding="16,12"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Right">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Spacing="12">
                            <TextBlock Text="Logros"
                                       FontFamily="{StaticResource Poppins}"
                                       FontWeight="SemiBold"
                                       FontSize="18"
                                       Foreground="#1A214A"
                                       VerticalAlignment="Center"/>
                            <Image Source="avares://Quibee/Assets/Images/Icons/TrophyDark.png"
                                   Width="18"
                                   Height="18"
                                   VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Background="Transparent"
                            BorderThickness="0"
                            Margin="0,2,10,2"
                            Padding="16,12"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Right">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Spacing="12">
                            <TextBlock Text="Progreso"
                                       FontFamily="{StaticResource Poppins}"
                                       FontWeight="SemiBold"
                                       FontSize="18"
                                       Foreground="#1A214A"
                                       VerticalAlignment="Center"/>
                            <Image Source="avares://Quibee/Assets/Images/Icons/ChartDark.png"
                                   Width="18"
                                   Height="18"
                                   VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Background="Transparent"
                            BorderThickness="0"
                            Margin="0,2,10,2"
                            Padding="16,12"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Right">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Spacing="12">
                            <TextBlock Text="Desafío"
                                       FontFamily="{StaticResource Poppins}"
                                       FontWeight="SemiBold"
                                       FontSize="18"
                                       Foreground="#1A214A"
                                       VerticalAlignment="Center"/>
                            <Image Source="avares://Quibee/Assets/Images/Icons/ProfileDark.png"
                                   Width="18"
                                   Height="18"
                                   VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" RowDefinitions="Auto,*" Margin="24,16,24,16">
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                <Border Grid.Column="0"
                        Background="#AE84D5"
                        CornerRadius="18"
                        Padding="16,10"
                        Margin="0,0,18,14">
                    <StackPanel Spacing="2">
                        <TextBlock Text="{Binding TituloLecciones}"
                                   FontFamily="{StaticResource LilitaOne}"
                                   FontSize="32"
                                   Foreground="#311B42"/>
                        <TextBlock Text="{Binding LevelDescription}"
                                   FontFamily="{StaticResource Poppins}"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Foreground="#311B42"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Button Grid.Column="1"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding InicioCommand}"
                        VerticalAlignment="Center">
                    <TextBlock Text="✖"
                               FontFamily="{StaticResource LilitaOne}"
                               FontSize="34"
                               Foreground="#FF6A67"/>
                </Button>
            </Grid>

            <Border Grid.Row="1"
                    Background="#232D63"
                    CornerRadius="20"
                    Padding="0,0,0,0">
                <ScrollViewer Name="MapScrollViewer"
                              Margin="10,10,10,10"
                              VerticalScrollBarVisibility="Visible"
                              HorizontalScrollBarVisibility="Disabled"
                              FlowDirection="RightToLeft">
                    <Canvas Width="980"
                            Height="{Binding CanvasHeight}"
                            Margin="24,0,20,0"
                            FlowDirection="LeftToRight">
                        <ItemsControl ItemsSource="{Binding Nodes}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas Width="980" Height="{Binding DataContext.CanvasHeight, ElementName=Root}"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:ThemeData">
                                    <Grid>
                                        <Grid.RenderTransform>
                                            <TranslateTransform X="{Binding PositionX}" Y="{Binding PositionY}"/>
                                        </Grid.RenderTransform>
                                        <Button x:Name="NodeButton"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Command="{Binding Command}">
                                            <StackPanel Spacing="8">
                                                <Image Source="{Binding Image}"
                                                       Width="{Binding ImageWidth}"
                                                       Height="{Binding ImageHeight}"
                                                       Stretch="Uniform"/>

                                                <TextBlock Text="{Binding Title}"
                                                           Width="176"
                                                           FontFamily="{StaticResource Poppins}"
                                                           FontWeight="SemiBold"
                                                           FontSize="16"
                                                           Foreground="#7CDAF3"
                                                           TextAlignment="Center"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Button>

                                        <Border Width="292"
                                                Margin="202,-10,0,0"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Top"
                                                Background="#2B336B"
                                                BorderBrush="#B35AFF"
                                                BorderThickness="3"
                                                CornerRadius="24"
                                                Padding="14,10"
                                                IsHitTestVisible="False"
                                                IsVisible="{Binding #NodeButton.IsPointerOver}">
                                            <StackPanel Spacing="8">
                                                <TextBlock Text="{Binding Title}"
                                                           FontFamily="{StaticResource LilitaOne}"
                                                           FontSize="17"
                                                           Foreground="#7CDAF3"/>
                                                <TextBlock Text="{Binding Description}"
                                                           FontFamily="{StaticResource Poppins}"
                                                           FontSize="13"
                                                           Foreground="#FFFFFF"
                                                           Opacity="0.9"
                                                           MaxWidth="250"
                                                           TextWrapping="Wrap"/>
                                                <Border Height="14"
                                                        Background="#3A3F57"
                                                        CornerRadius="7">
                                                    <Border Width="{Binding LessonProgressWidth}"
                                                            Height="14"
                                                            Background="#F85CB0"
                                                            CornerRadius="7"
                                                            HorizontalAlignment="Left"/>
                                                </Border>
                                                <DockPanel LastChildFill="False">
                                                    <TextBlock Text="Progreso"
                                                               FontFamily="{StaticResource Poppins}"
                                                               FontSize="12"
                                                               Foreground="#7CDAF3"/>
                                                    <TextBlock DockPanel.Dock="Right"
                                                               Text="{Binding LessonProgressPercentage, StringFormat='{}{0}%'}"
                                                               FontFamily="{StaticResource LilitaOne}"
                                                               FontSize="14"
                                                               Foreground="#F4D34E"/>
                                                </DockPanel>
                                                <TextBlock Text="Haz clic para abrir la lección"
                                                           FontFamily="{StaticResource Poppins}"
                                                           FontSize="12"
                                                           Foreground="#DADFFF"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Canvas>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
