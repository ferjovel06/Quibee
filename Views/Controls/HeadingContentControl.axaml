<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="60"
             x:Class="Quibee.Views.Controls.HeadingContentControl">

    <Border Background="#7CDAF3"
            CornerRadius="10"
            Padding="20,10"
            Margin="0,10,0,10"
            x:Name="HeadingBorder">
        
        <TextBlock x:Name="HeadingText"
                   FontFamily="{StaticResource LilitaOne}"
                   FontSize="24"
                   Foreground="#311B42"
                   TextWrapping="Wrap" />
    </Border>

</UserControl>
