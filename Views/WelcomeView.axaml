<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Quibee.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1920" d:DesignHeight="1080"
             x:Class="Quibee.Views.WelcomeView"
             x:DataType="vm:WelcomeViewModel">
    
    <!-- ============================================ -->
    <!-- ESTILOS PERSONALIZADOS                      -->
    <!-- ============================================ -->
    <UserControl.Styles>
        <!-- Estilo del botón principal de bienvenida -->
        <Style Selector="Button.welcomeButton">
            <Setter Property="Background" Value="#D51A1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="{StaticResource LilitaOne}"/>
            <Setter Property="FontSize" Value="30"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="CornerRadius" Value="30"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.welcomeButton:pointerover">
            <Setter Property="Background" Value="#D62839"/>
        </Style>
    </UserControl.Styles>

    <!-- ============================================ -->
    <!-- CONTENEDOR PRINCIPAL (responsive full-screen) -->
    <!-- ============================================ -->
    <Border Background="#311B42">
        <Grid ClipToBounds="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.35*"/>
                <ColumnDefinition Width="2.15*"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <!-- Decoración -->
            <Image Grid.Row="0" Grid.Column="0"
                   Source="/Assets/Images/ShootingStar.png"
                   MaxWidth="300" MaxHeight="300"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"
                   Margin="30,10,0,0"
                   RenderOptions.BitmapInterpolationMode="HighQuality"/>

            <Image Grid.Row="0" Grid.Column="1"
                   Source="/Assets/Images/1.png"
                   MaxWidth="110" MaxHeight="110"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top"
                   Margin="0,6,0,0"
                   RenderOptions.BitmapInterpolationMode="HighQuality"/>

            <Image Grid.Row="0" Grid.Column="2"
                   Source="/Assets/Images/Saturn.png"
                   MaxWidth="320" MaxHeight="320"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Top"
                   Margin="0,10,12,0"
                   Opacity="0.95"
                   Stretch="Uniform"/>

            <Image Grid.Row="2" Grid.Column="0"
                   Source="/Assets/Images/Earth.png"
                   MaxWidth="260" MaxHeight="260"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Bottom"
                   Margin="12,0,0,0"
                   Opacity="0.9"
                   Stretch="Uniform"/>

            <Image Grid.Row="2" Grid.Column="1"
                   Source="/Assets/Images/3.png"
                   MaxWidth="120" MaxHeight="120"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Bottom"
                   Margin="0,0,80,8"
                   RenderOptions.BitmapInterpolationMode="HighQuality"/>

            <Image Grid.Row="1" Grid.Column="2"
                   Source="/Assets/Images/2.png"
                   MaxWidth="130" MaxHeight="130"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center"
                   Margin="0,0,36,0"
                   RenderOptions.BitmapInterpolationMode="HighQuality"/>

            <!-- Bloque central responsive: robot + texto + CTA -->
            <Viewbox Grid.Row="1" Grid.ColumnSpan="3"
                     Stretch="Uniform"
                     StretchDirection="Both"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     Margin="20,0,20,0"
                     MaxWidth="1250">
                <Grid Width="1040" Height="430">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360"/>
                        <ColumnDefinition Width="680"/>
                    </Grid.ColumnDefinitions>

                    <Image Grid.Column="0"
                           Source="/Assets/Images/Robot.png"
                           Width="340"
                           Height="410"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           RenderOptions.BitmapInterpolationMode="HighQuality"/>

                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Margin="0,6,0,0"
                                Spacing="8"
                                RenderTransformOrigin="0,0.5">
                        <StackPanel.RenderTransform>
                            <RotateTransform Angle="-3"/>
                        </StackPanel.RenderTransform>

                        <TextBlock Text="Bienvenido"
                                  FontFamily="{StaticResource LilitaOne}"
                                  FontSize="56"
                                  Foreground="#F25E67"
                                  HorizontalAlignment="Left"/>

                        <TextBlock Text="Matemáticas"
                                  FontFamily="{StaticResource LilitaOne}"
                                  FontSize="96"
                                  Foreground="#F2F2F2"
                                  HorizontalAlignment="Left"
                                  TextWrapping="NoWrap"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Spacing="16">
                            <TextBlock Text="con"
                                      FontFamily="{StaticResource LilitaOne}"
                                      FontSize="96"
                                      Foreground="#F2F2F2"/>
                            <TextBlock Text="Q-BIT"
                                      FontFamily="{StaticResource LilitaOne}"
                                      FontSize="96"
                                      Foreground="#7CDAF3"/>
                        </StackPanel>

                        <Button Classes="welcomeButton"
                                Content="Inicio"
                                Command="{Binding StartCommand}"
                                HorizontalAlignment="Left"
                                Margin="20,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Viewbox>
        </Grid>
    </Border>
</UserControl>
